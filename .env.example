# PostgreSQL (Supabase, Railway, Neon, local...)
DATABASE_URL=postgresql://postgres:password@localhost:5432/noctua

# Neo4j Aura
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu_password_aqui

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=zephyr:latest
